   "source": [
    "## EXTRACTING ALL RESULTS\n",
    "\n",
    "import configparser  # to read the settings file\n",
    "import re   # to read the settings file\n",
    "\n",
    "Normalized_meanwtd_difference = np.zeros(len(folders))  # Mean of the water table depth difference, in [%]\n",
    "Average_transient_nRMSE = np.zeros(len(folders))  # Mean of the water table depth difference, in [%]\n",
    "Permeability_values = np.zeros(len(folders))\n",
    "Porosity_values = np.zeros(len(folders))\n",
    "RiverPercentCoef_values = np.zeros(len(folders))\n",
    "KGE_values = np.zeros(len(folders))\n",
    "\n",
    "## Loading files containing basin grid information\n",
    "Size = np.loadtxt(Inputs_file_modflow + 'UB_limits.txt')\n",
    "#res_ModFlow = (Size[1]-Size[0])/(Size[5]-1)  # in [m]\n",
    "basin = np.loadtxt(Inputs_file_modflow + 'Basin_limits.txt')\n",
    "# Map dimensions\n",
    "#ncol = int((Size[1]-Size[0])/res_ModFlow)+1 \n",
    "#nrow = int(abs((Size[3]-Size[2])/res_ModFlow)+1)\n",
    "ncol = int(Size[5])\n",
    "nrow = int(Size[4])\n",
    "basin = basin.reshape(nrow,ncol)              # ModFlow format\n",
    "    \n",
    "# Topography\n",
    "# Warning soil thickness could be different for each model!! REPLACE OBSERVED DATA BY OUTPUT FOLDER\n",
    "ds = xr.open_dataset(path_model_outputs + '/' + folders[0] + '/' + 'modflowtotalSoilThickness_totalend.nc')\n",
    "Soil_thickness = ds['modflowtotalSoilThickness_totalend'][:].data \n",
    "ds.close()\n",
    "Top = np.loadtxt(Inputs_file_modflow + 'Topo.txt')\n",
    "Topo_ModFlow = Top.reshape(nrow,ncol) + Soil_thickness # We need to add soil thickness to compare WTD\n",
    "\n",
    "# Observed water table\n",
    "Number_of_observed_dates = 9  # It depends on the simulating period\n",
    "Measured_watertabledepth = np.zeros((382, Number_of_observed_dates)) # 2D array containing measured data: 382 boreholes for Bhima\n",
    "wb = xlrd.open_workbook(path_observed_data+ \"UB_GW_DataProcessed.xls\")\n",
    "sh = wb.sheet_by_name(u'Sheet1')\n",
    "for il in range(np.shape(Measured_watertabledepth)[0]):\n",
    "    for ic in range(np.shape(Measured_watertabledepth)[1]):\n",
    "        val=sh.row_values(il+1)[ic]\n",
    "        if val == '':\n",
    "            Measured_watertabledepth[il][ic] = np.nan\n",
    "        else:\n",
    "            Measured_watertabledepth[il][ic] = val\n",
    "            \n",
    "# ModFlow time\n",
    "ds = xr.open_dataset(path_model_outputs + '/' + folders[0] + '/' + 'modflowWaterLevel_monthend.nc')         # Coord System: epsg 4326\n",
    "Time_ModFlow = ds['time'][:].data\n",
    "Time_ModFlowV2 = (Time_ModFlow - np.datetime64('1970-01-01T00:00:00Z')) / np.timedelta64(1, 's')\n",
    "Time_ModFlowV3 = np.zeros(len(Time_ModFlow))\n",
    "for it in range(len(Time_ModFlow)):\n",
    "    dd = datetime.utcfromtimestamp(Time_ModFlowV2[it])\n",
    "    Time_ModFlowV3[it] = dd.toordinal()\n",
    "ds.close()  \n",
    "\n",
    "# Associated date\n",
    "Measured_dates = np.zeros(np.shape(Measured_watertabledepth)[1])\n",
    "for ic in range(np.shape(Measured_watertabledepth)[1]):\n",
    "    # dd = datetime.fromordinal(datetime(1900, 1, 1).toordinal() + int(sh.row_values(0)[0]) - 2).strftime('%Y%m%d')\n",
    "    Measured_dates[ic] = datetime(1900, 1, 1).toordinal() + int(sh.row_values(0)[ic]) - 2\n",
    "\n",
    "for ll in range(len(folders)): # for each folder (=each simulation)\n",
    "    \n",
    "    print('data from this folder are extracted : ', folders[ll] , ' (', ll, '/', len(folders), ' done)')\n",
    "    # Run the function\n",
    "    if ll == 0:\n",
    "        Criteria = CompareWaterTable(path_model_outputs + '/' + folders[ll], path_observed_data,\n",
    "                                     Size, basin, ncol, nrow, res_ModFlow,\n",
    "                                     Measured_watertabledepth, Measured_dates, Number_of_observed_dates,\n",
    "                                     Topo_ModFlow, Time_ModFlowV3, [], first_run=True)\n",
    "        accepted_piezo = Criteria[-1]\n",
    "    else:\n",
    "        Criteria = CompareWaterTable(path_model_outputs + '/' + folders[ll], path_observed_data,\n",
    "                                     Size, basin, ncol, nrow, res_ModFlow,\n",
    "                                     Measured_watertabledepth, Measured_dates, Number_of_observed_dates,\n",
    "                                     Topo_ModFlow, Time_ModFlowV3, accepted_piezo, first_run=False)\n",
    "        \n",
    "    Average_transient_nRMSE[ll] = Criteria[0]\n",
    "    Normalized_meanwtd_difference[ll] = Criteria[1]\n",
    "    \n",
    "    #config = ExtParser()\n",
    "    config = configparser.RawConfigParser()\n",
    "    config.optionxform = str\n",
    "    config.sections()\n",
    "    config.read(path_model_outputs + '/' + folders[ll] + '/' +\n",
    "                'settings_CWatM_Sept25_template-Run' + folders[ll] + '.ini')\n",
    "    \n",
    "    Permeability_values[ll] = float(config.get('CALIBRATION', 'permeability'))\n",
    "    Porosity_values[ll] = float(config.get('CALIBRATION', 'poro'))\n",
    "    RiverPercentCoef_values[ll] = float(config.get('CALIBRATION', 'gwRiverMult'))\n",
    "    # using the dictionnary created before to associate the KGE criteria corresponding to simulation name\n",
    "    KGE_values[ll] = dict_discharge_criter[folders[ll]]\n",
    "\n",
    "    "
   ]
  },
